# Production / direct API URL (full URL, no trailing slash required)
# REACT_APP_API_URL=https://your-api.example.com/api
# VITE_API_URL=https://your-api.example.com/api

# Local dev with Vite proxy (recommended): do NOT set VITE_API_URL — requests go to /api on the dev server.

# Optional: where Vite should proxy /api when using `npm run dev`
# VITE_PROXY_TARGET=http://127.0.0.1:5000
